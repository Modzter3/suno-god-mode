# Copy to .env.local for `vercel dev` (optional). In production, set these in Vercel → Project → Settings → Environment Variables.

OPENROUTER_API_KEY=sk-or-v1-...
# Optional: default when the UI is on "Server default" (see https://openrouter.ai/models)
# OPENROUTER_MODEL=openai/gpt-4o-mini
# Optional: your public site URL for OpenRouter HTTP-Referer (defaults to https://YOUR_PROJECT.vercel.app)
# OPENROUTER_SITE_URL=https://your-app.vercel.app

# Optional: Vercel → Storage → Postgres (Neon). Link the database to the project; POSTGRES_URL is injected automatically.
# Without it, past results are still saved in the browser (localStorage).
# POSTGRES_URL=postgres://...
